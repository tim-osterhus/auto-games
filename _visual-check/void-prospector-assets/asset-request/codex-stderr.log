}

def save_transparent(src, dst, size, fill=0.9):
    im = Image.open(src).convert('RGBA')
    alpha = im.getchannel('A')
    bbox = alpha.getbbox()
    if not bbox:
        raise RuntimeError(f'No opaque pixels in {src}')
    crop = im.crop(bbox)
    max_w = int(size[0] * fill)
    max_h = int(size[1] * fill)
    scale = min(max_w / crop.width, max_h / crop.height)
    new_size = (max(1, round(crop.width * scale)), max(1, round(crop.height * scale)))
    resized = crop.resize(new_size, Image.Resampling.LANCZOS)
    canvas = Image.new('RGBA', size, (0, 0, 0, 0))
    canvas.paste(resized, ((size[0] - resized.width)//2, (size[1] - resized.height)//2), resized)
    canvas.save(dst)

def save_opaque_fit(src, dst, size):
    im = Image.open(src).convert('RGB')
    fit = ImageOps.fit(im, size, method=Image.Resampling.LANCZOS, centering=(0.5, 0.5))
    fit.save(dst)

save_transparent(sources['ship-decal.png'], outdir / 'ship-decal.png', (256, 256), fill=0.9)
save_opaque_fit(sources['asteroid-ore-glow.png'], outdir / 'asteroid-ore-glow.png', (512, 512))
save_opaque_fit(sources['station-dock-panel.png'], outdir / 'station-dock-panel.png', (512, 256))
save_transparent(sources['pirate-marker.png'], outdir / 'pirate-marker.png', (256, 256), fill=0.92)
save_opaque_fit(sources['arcade-title-card.png'], outdir / 'arcade-title-card.png', (800, 450))

