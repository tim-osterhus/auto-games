import json
from pathlib import Path
from PIL import Image
manifest_path = Path('/mnt/f/_evolve/millrace-games/auto-games/_visual-check/dark-factory-dispatch-assets/asset-request-manifest.json')
with manifest_path.open() as f:
    manifest = json.load(f)
assert manifest['status'] == 'complete'
for asset in manifest['assets']:
    p = Path(asset['path'])
    assert p.exists(), p
    im = Image.open(p)
    assert im.size == (asset['width'], asset['height']), (p, im.size, asset['width'], asset['height'])
    if p.name == 'arcade-title-card.png':
        assert im.mode == 'RGB', (p, im.mode)
    else:
        rgba = im.convert('RGBA')
        assert rgba.getchannel('A').getbbox(), p
        assert [rgba.getchannel('A').getpixel(c) for c in [(0,0), (95,0), (0,95), (95,95)]] == [0, 0, 0, 0], p
print('manifest and assets validated')
